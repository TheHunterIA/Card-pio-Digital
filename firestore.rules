service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function isMasterAdmin() {
      return isSignedIn() && (request.auth.token.email is string) && request.auth.token.email.lower() == 'cleitonprado2026@gmail.com';
    }
    
    function isAdmin() { 
      return isMasterAdmin() || (isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        ((request.auth.token.email is string) && exists(/databases/$(database)/documents/authorized_admins/$(request.auth.token.email.lower())))
      )); 
    }
    function isDriver() {
      return isSignedIn() && (request.auth.token.email is string) && exists(/databases/$(database)/documents/authorized_drivers/$(request.auth.token.email.lower()));
    }
    function isWaiter() {
      return isMasterAdmin() || (isSignedIn() && (request.auth.token.email is string) && exists(/databases/$(database)/documents/authorized_waiters/$(request.auth.token.email.lower())));
    }
    function isPorteiro() {
      return isMasterAdmin() || (isSignedIn() && (request.auth.token.email is string) && exists(/databases/$(database)/documents/authorized_porters/$(request.auth.token.email.lower())));
    }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- State Machine Helpers ---
    function isStatusTransitionValid(oldStatus, newStatus) {
      // Regras de transição lógica de estado
      return (oldStatus == newStatus)
          || (oldStatus == 'na-fila' && newStatus == 'preparando')
          || (oldStatus == 'na-fila' && newStatus == 'cancelado')
          || (oldStatus == 'preparando' && (newStatus == 'servido' || newStatus == 'pronto-entrega' || newStatus == 'cancelado'))
          || (oldStatus == 'pronto-entrega' && (newStatus == 'em-rota' || newStatus == 'cancelado'))
          || (oldStatus == 'servido' && newStatus == 'finalizado')
          || (oldStatus == 'em-rota' && newStatus == 'finalizado')
          // Admin override para cancelamento (exceto se já tiver finalizado)
          || (isAdmin() && oldStatus != 'finalizado' && newStatus == 'cancelado');
    }

    // --- Validation Helpers ---

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'image', 'isActive', 'extras'])
          && (data.keys().size() >= 7 && data.keys().size() <= 10)
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.description is string && data.description.size() <= 1000
          && data.price is number && data.price >= 0
          && data.category is string && data.category.size() > 0 && data.category.size() <= 60
          && data.isActive is bool
          && data.extras is list;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'customerName', 'type', 'items', 'total', 'status', 'paymentStatus', 'createdAt'])
          && (data.keys().size() >= 8 && data.keys().size() <= 40)
          && data.userId is string && data.userId.size() > 0
          && data.customerName is string && data.customerName.size() <= 100
          && data.type in ['dine-in', 'delivery']
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total >= 0
          && data.status in ['na-fila', 'preparando', 'saiu-entrega', 'finalizado', 'cancelado', 'pronto-entrega', 'em-rota', 'servido']
          && data.paymentStatus in ['pending', 'paid']
          && data.createdAt is timestamp
          && (!('updatedAt' in data) || data.updatedAt is timestamp)
          && (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 20))
          && (!('tableNumber' in data) || (data.tableNumber is string && data.tableNumber.size() <= 20))
          && (!('address' in data) || (data.address is string && data.address.size() <= 500))
          && (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5))
          && (!('billRequested' in data) || data.billRequested is bool);
    }

    // --- Collections ---

    // Orders Collection
    match /orders/{orderId} {
      allow list: if isAdmin() || isWaiter() || isPorteiro() || isDriver() 
                  || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.deviceId == request.auth.uid));
      
      allow get: if isValidId(orderId) && (isAdmin() || isWaiter() || isPorteiro() || isDriver() 
                  || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.deviceId == request.auth.uid)));
      
      allow create: if isValidId(orderId)
                    && isValidOrder(incoming())
                    && incoming().createdAt == request.time
                    && (incoming().userId == request.auth.uid || isWaiter() || isAdmin())
                    && (isWaiter() || isAdmin() || (incoming().keys().hasAll(['whatsapp']) && incoming().whatsapp.size() >= 8));

      allow update: if isValidId(orderId) 
                    && isValidOrder(incoming())
                    && (
                      isAdmin() || isWaiter() ||
                      // Driver Actions
                      (isDriver() && (
                        // Accept order: must be pronto-entrega -> em-rota
                        (existing().status == 'pronto-entrega' && incoming().status == 'em-rota' && incoming().driverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'updatedAt'])) ||
                        // Location update: status must be em-rota
                        (existing().status == 'em-rota' && existing().driverId == request.auth.uid && incoming().status == 'em-rota' && incoming().diff(existing()).affectedKeys().hasOnly(['driverLocation', 'updatedAt'])) ||
                        // Complete delivery: em-rota -> finalizado
                        (existing().status == 'em-rota' && existing().driverId == request.auth.uid && incoming().status == 'finalizado' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                      )) ||
                      // Customer actions
                      (isSignedIn() && (existing().userId == request.auth.uid || existing().deviceId == request.auth.uid) && (
                        // Finalize manually: only if allowed by state machine
                        (incoming().status == 'finalizado' && isStatusTransitionValid(existing().status, incoming().status) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                        // Payment flow: pending -> paid (immutable once paid)
                        (incoming().paymentStatus == 'paid' && existing().paymentStatus == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'paymentMethod', 'updatedAt'])) ||
                        // Bill request: false -> true (cannot be reversed)
                        (incoming().billRequested == true && existing().billRequested != true && incoming().diff(existing()).affectedKeys().hasOnly(['billRequested', 'updatedAt'])) ||
                        // Rating: can only be set once
                        (incoming().rating >= 1 && incoming().rating <= 5 && !('rating' in existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'updatedAt']))
                      ))
                    )
                    // Global Integrity Guards
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (incoming().status == existing().status || isStatusTransitionValid(existing().status, incoming().status));
    }

    // Menu Collection
    match /menu/{menuId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(menuId) && isValidMenuItem(incoming());
    }

    // Clientes Collection
    match /clientes/{whatsapp} {
      allow read: if isAdmin() || isWaiter();
      allow get: if isSignedIn() && (existing().uid == request.auth.uid);
      allow create, update: if isSignedIn() && incoming().uid == request.auth.uid 
                            && (whatsapp == incoming().whatsapp || isAdmin())
                            && incoming().lastSeen == request.time;
    }

    // Admins/Staff
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isMasterAdmin();
    }
    match /authorized_admins/{docId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
    match /authorized_drivers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /authorized_waiters/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /authorized_porters/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupon Usage
    match /couponUsage/{usageId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidId(usageId) 
                    && incoming().keys().hasAll(['uid', 'code', 'count', 'updatedAt'])
                    && incoming().updatedAt == request.time;
      allow update: if (isAdmin() || (isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid))
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['count', 'updatedAt']);
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin() || isWaiter() || isSignedIn();
      
      match /orders/{orderId} {
        allow read: if true;
        allow create: if (isAdmin() || isWaiter() || isSignedIn()) 
                      && isValidId(orderId) 
                      && isValidOrder(incoming()) 
                      && incoming().createdAt == request.time;
        allow update: if (isAdmin() || isWaiter() || (isSignedIn() && (existing().userId == request.auth.uid || existing().deviceId == request.auth.uid)))
                      && isValidOrder(incoming())
                      && incoming().updatedAt == request.time
                      && (incoming().status == existing().status || isStatusTransitionValid(existing().status, incoming().status))
                      && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'billRequested', 'paymentStatus', 'paymentMethod']);
      }
    }
  }
}
