{
  "entities": {
    "menuItem": {
      "title": "Menu Item",
      "description": "A product available in the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "isActive": { "type": "boolean" },
        "trackStock": { "type": "boolean" },
        "stockQuantity": { "type": "number" },
        "extras": { "type": "array" }
      },
      "required": ["name", "price", "category", "isActive"]
    },
    "staff": {
      "title": "Staff Member",
      "description": "Authorized staff member (Waiter, Driver, Porter)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["waiter", "driver", "porter", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "couponUsage": {
      "title": "Coupon Usage",
      "description": "Tracks how many times a user has used a coupon",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "code": { "type": "string" },
        "count": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "code", "count", "updatedAt"]
    },
    "deliverySettings": {
      "title": "Delivery Settings",
      "description": "Radius-based fees and peak hour rules",
      "type": "object",
      "properties": {
        "radii": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "maxDistance": { "type": "number" },
              "feePerKm": { "type": "number" }
            }
          }
        },
        "peakHours": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "dayOfWeek": { "type": "number" },
              "startHour": { "type": "string" },
              "endHour": { "type": "string" },
              "feeMultiplier": { "type": "number" }
            }
          }
        },
        "baseLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "freeDeliveryThreshold": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/settings/delivery": {
      "schema": "deliverySettings",
      "description": "Advanced delivery fee configurations."
    },
    "/authorized_staff/{email}": {
      "schema": "staff",
      "description": "Whitelist of authorized staff members and their roles."
    },
    "/couponUsage/{usageId}": {
      "schema": "couponUsage",
      "description": "Tracks usage of coupons per user."
    }
  }
}
